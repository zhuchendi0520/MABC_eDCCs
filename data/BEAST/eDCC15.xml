			<taxon idref="ERR5412653"/>
			GGCAGGGCGTGACTTGCAACTGGCTCCCCGGTCAGCCAGCGGGGGCGGAAGCACAGTTGGGGCGCGGACCCGCGCGCAAGCAGAGTGGTCACTGCGCGTTTCGGACGCGGACTCGAGTATTGCCTGCGGCGTCCGGAAGATTGTGCGTCTGTGCGCCTCTAGTGACTACTG
		</sequence>
